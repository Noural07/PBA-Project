# ============================================================================
# Skabelon for lokalt udviklingsmiljø.
# Kopier til ".env" og udfyld med konkrete værdier. ".env" er git-ignoreret.
# Ingen hemmeligheder må committes.
# ============================================================================

# .NET runtime
ASPNETCORE_ENVIRONMENT=Development

# Forsink Gatus' første polling-runde (sekunder). Default 60s er valgt så
# microservicene har gennemført JIT-opvarmning og første GC-cyklus, før
# Gatus rammer dem. Sæt til 0 for ingen forsinkelse.
GATUS_STARTUP_DELAY_SECONDS=60

# PostgreSQL
POSTGRES_USER=pba
POSTGRES_PASSWORD=change-me-postgres
POSTGRES_DB=pba

# RabbitMQ
RABBITMQ_USER=pba
RABBITMQ_PASSWORD=change-me-rabbitmq

# Grafana admin-bruger
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me-grafana

# Trendlog API (eksternt)
TRENDLOG_API_KEY=replace-with-real-trendlog-bearer-token
TRENDLOG_BASE_URL=https://api.trendlog.io

# Gemini AI (eksternt)
GEMINI_API_KEY=replace-with-real-gemini-key
GEMINI_BASE_URL=https://generativelanguage.googleapis.com
GEMINI_MODEL=gemini-2.5-flash

# AlertingService – CORS-allowlist for SSE-frontend'en. Sættes til den origin
# som AlertFeed-frontend'en serveres fra (default: docker-compose-mappet port).
ALERTING_FRONTEND_ORIGIN=http://localhost:5173

# Frontend – build-time URL der peger på AlertingService' /alerts/stream-endpoint.
# Indlejres af Vite ved build (multi-stage Dockerfile) og kan ikke ændres på runtime.
VITE_ALERTING_BASE_URL=http://localhost:5104
